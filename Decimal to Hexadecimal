#include <stdio.h>

int main()
{
    int n, rem;
    char hex[20];
    int i = 0, j;

    printf("Enter Decimal Number: ");
    scanf("%d", &n);

    while(n != 0)
    {
        rem = n % 16;

        if(rem < 10)
            hex[i] = rem + 48;
        else
            hex[i] = rem + 55;

        n = n / 16;
        i++;
    }

    printf("Hexadecimal = ");

    for(j = i - 1; j >= 0; j--)
    {
        printf("%c", hex[j]);
    }

    return 0;
}
