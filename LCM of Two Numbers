#include <stdio.h>

int main()
{
    int a, b, max;

    printf("Enter Two Numbers: ");
    scanf("%d%d", &a, &b);

    max = (a > b) ? a : b;

    while(1)
    {
        if(max % a == 0 && max % b == 0)
        {
            printf("LCM = %d", max);
            break;
        }

        max++;
    }

    return 0;
}
Sample Output
Enter Two Numbers: 6 8
LCM = 24
