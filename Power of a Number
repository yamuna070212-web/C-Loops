#include <stdio.h>

int main()
{
    int base, power, i;
    long long result = 1;

    printf("Enter Base and Power: ");
    scanf("%d%d", &base, &power);

    for(i = 1; i <= power; i++)
    {
        result = result * base;
    }

    printf("Answer = %lld", result);

    return 0;
}
