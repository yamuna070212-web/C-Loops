#include <stdio.h>

int main()
{
    int n, octal[20], i = 0, j;

    printf("Enter Decimal Number: ");
    scanf("%d", &n);

    while(n > 0)
    {
        octal[i] = n % 8;
        n = n / 8;
        i++;
    }

    printf("Octal = ");

    for(j = i - 1; j >= 0; j--)
    {
        printf("%d", octal[j]);
    }

    return 0;
}
Sample Output
Enter Decimal Number: 25
Octal = 31
