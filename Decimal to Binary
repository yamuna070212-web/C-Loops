#include <stdio.h>

int main()
{
    int n, binary[32], i = 0, j;

    printf("Enter Decimal Number: ");
    scanf("%d", &n);

    while(n > 0)
    {
        binary[i] = n % 2;
        n = n / 2;
        i++;
    }

    printf("Binary = ");

    for(j = i - 1; j >= 0; j--)
    {
        printf("%d", binary[j]);
    }

    return 0;
}
Sample Output
Enter Decimal Number: 10
Binary = 1010
